{
  "compilerOptions": {
    /* Rollup-friendly output */
    "module": "ESNext",
    "moduleResolution": "Bundler",

    /* Pick a modern target; Rollup/IIFE stays the same */
    "target": "ES2018",
    "lib": ["DOM", "ES2018"],

    /* Allow gradual migration from JS -> TS */
    "allowJs": true,
    "checkJs": false,

    /* Nice-to-haves */
    "strict": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Keep TS build artifacts out of dist */
    //"outDir": "./.tsbuild",
    "sourceMap": true,
    "declaration": false,
    "noEmit": true
    //"noEmitOnError": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".tsbuild"]
}
